        "completeHistoryYears": 0,
        "publicPullRequests": 1,
        "patch": "small_with_tests_and_passing_ci"
      },
      "expected": {
        "summaryState": "limited_evidence",
        "overallConfidence": "low",
        "reviewPriority": "prioritize",
        "reasonCodes": [
          "LIMITED_PUBLIC_HISTORY",
          "CI_PASSING",
          "TESTS_CHANGED"
        ],
        "dimensionStates": {
          "tenure_continuity": "uncertain",
          "independent_open_source_record": "uncertain",
          "merge_follow_through": "uncertain",
          "collaboration": "uncertain",
          "relevant_experience": "uncertain",
          "integrity_gaming_resistance": "uncertain"
        },
        "comment": {
          "numericScoresIncluded": false,
          "privateEvidenceIncluded": false,
          "mustContain": [
            "Limited evidence",
            "Priority is based on patch readiness; contributor history remains limited"
          ],
          "mustNotContain": [
            "low trust",
            "untrusted",
            "suspicious"
          ]
        },
        "check": {
          "state": "completed",
          "conclusion": "success"
        }
      }
    },
