{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mergesignal.dev/schemas/pr-comment-render-v1.json",
  "title": "MergeSignal template-only PR comment render model",
  "description": "The only structured input accepted by the PR-comment renderer. It contains no free-form public copy, numeric reputation score, private source link, or arbitrary destination URL.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "assessmentId",
    "target",
    "summaryState",
    "overallConfidence",
    "reviewPriority",
    "reviewPriorityBasis",
    "dimensions",
    "coverage",
    "patchContext",
    "explanation",
    "evidenceLinks",
    "sourceSetDigest",
    "assessmentVersion"
  ],
  "properties": {
    "schemaVersion": { "const": "1.0.0" },
    "assessmentId": { "type": "string", "format": "uuid" },
    "target": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "installationId",
        "repositoryNodeId",
        "repositoryVisibility",
        "pullRequestNodeId",
        "pullRequestNumber",
        "headSha",
        "generation",
        "markerVersion"
      ],
      "properties": {
        "installationId": { "type": "integer", "minimum": 1 },
        "repositoryNodeId": { "type": "string", "minLength": 1 },
        "repositoryVisibility": { "enum": ["public", "private", "internal"] },
        "pullRequestNodeId": { "type": "string", "minLength": 1 },
        "pullRequestNumber": { "type": "integer", "minimum": 1 },
        "headSha": { "$ref": "#/$defs/sha" },
        "generation": { "type": "integer", "minimum": 1 },
        "markerVersion": { "const": "1" }
      }
    },
    "summaryState": {
      "enum": [
        "established_evidence",
        "developing_evidence",
        "limited_evidence",
        "needs_manual_inspection"
      ]
    },
    "overallConfidence": { "enum": ["low", "medium", "high"] },
    "reviewPriority": {
      "enum": ["not_enabled", "prioritize", "standard", "inspect_first"]
    },
    "reviewPriorityBasis": {
      "enum": ["disabled", "reputation_and_patch", "patch_only", "standard", "inspection"]
    },
    "dimensions": { "$ref": "#/$defs/dimensions" },
    "coverage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["requestedWindowYears", "completeYears", "freshAsOf", "reasonCodes"],
      "properties": {
        "requestedWindowYears": { "type": "integer", "minimum": 1, "maximum": 5 },
        "completeYears": { "type": "integer", "minimum": 0, "maximum": 5 },
        "freshAsOf": { "type": "string", "format": "date-time" },
        "reasonCodes": { "$ref": "#/$defs/reasonCodes" }
      }
    },
    "patchContext": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ciState",
        "scope",
        "linkedIssue",
        "testPathState",
        "sensitivePathState",
        "reasonCodes"
      ],
      "properties": {
        "ciState": { "enum": ["passing", "failing", "pending", "missing", "unknown"] },
        "scope": { "enum": ["small", "medium", "large", "unknown"] },
        "linkedIssue": { "type": "boolean" },
        "testPathState": { "enum": ["changed", "unchanged", "unknown"] },
        "sensitivePathState": { "enum": ["changed", "unchanged", "unknown"] },
        "reasonCodes": { "$ref": "#/$defs/reasonCodes" }
      }
    },
    "explanation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "reasonCodes", "claimReasonCodes", "caveatKeys"],
      "properties": {
        "status": { "enum": ["complete", "deterministic_fallback"] },
        "reasonCodes": { "$ref": "#/$defs/reasonCodes" },
        "claimReasonCodes": {
          "type": "array",
          "maxItems": 3,
          "uniqueItems": true,
          "items": { "$ref": "https://mergesignal.dev/schemas/reason-code-v1.json" }
        },
        "caveatKeys": {
          "type": "array",
          "minItems": 1,
          "maxItems": 3,
          "uniqueItems": true,
          "items": {
            "enum": [
              "PUBLIC_HISTORY_NOT_PATCH_CORRECTNESS",
              "PUBLIC_HISTORY_MAY_BE_INCOMPLETE",
              "MODEL_INTERPRETATION",
              "CONTEXTUALIZATION_UNAVAILABLE"
            ]
          }
        }
      }
    },
    "evidenceLinks": {
      "type": "array",
      "maxItems": 3,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/evidenceLink" }
    },
    "sourceSetDigest": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "assessmentVersion": {
      "type": "string",
      "minLength": 1,
      "maxLength": 80,
      "pattern": "^[a-z0-9][a-z0-9._-]*$"
    }
  },
  "$defs": {
    "dimensions": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tenure_continuity",
        "independent_open_source_record",
        "merge_follow_through",
        "collaboration",
        "relevant_experience",
        "integrity_gaming_resistance"
      ],
      "properties": {
        "tenure_continuity": { "$ref": "#/$defs/commentDimension" },
        "independent_open_source_record": { "$ref": "#/$defs/commentDimension" },
        "merge_follow_through": { "$ref": "#/$defs/commentDimension" },
        "collaboration": { "$ref": "#/$defs/commentDimension" },
        "relevant_experience": { "$ref": "#/$defs/commentDimension" },
        "integrity_gaming_resistance": { "$ref": "#/$defs/commentDimension" }
      }
    },
    "commentDimension": {
      "type": "object",
      "additionalProperties": false,
      "required": ["state", "reasonCodes"],
      "properties": {
        "state": {
          "enum": ["strong", "moderate", "limited", "uncertain", "manual_inspection"]
        },
        "reasonCodes": { "$ref": "#/$defs/reasonCodes" }
      }
    },
    "evidenceLink": {
      "type": "object",
      "additionalProperties": false,
      "required": ["evidenceId", "evidenceType", "url", "visibility", "appliesTo"],
      "properties": {
        "evidenceId": { "type": "string", "minLength": 1 },
        "evidenceType": { "type": "string", "pattern": "^[A-Z][A-Z0-9_]+$" },
        "url": {
          "type": "string",
          "format": "uri",
          "maxLength": 2048,
          "pattern": "^https://github\\.com/[^?#]+$"
        },
        "visibility": { "const": "PUBLIC_GLOBAL" },
        "appliesTo": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "enum": [
              "tenure_continuity",
              "independent_open_source_record",
              "merge_follow_through",
              "collaboration",
              "relevant_experience",
              "integrity_gaming_resistance",
              "coverage",
              "patch_context",
              "explanation"
            ]
          }
        }
      }
    },
    "reasonCodes": {
      "type": "array",
      "items": { "$ref": "https://mergesignal.dev/schemas/reason-code-v1.json" },
      "uniqueItems": true
    },
    "sha": { "type": "string", "pattern": "^[0-9a-f]{40}$" }
  }
}
