{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mergesignal.dev/schemas/judgment-traceability-registry-v1.json",
  "title": "MergeSignal judgment traceability registry",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "judgments"],
  "properties": {
    "version": {
      "const": "1.0.0"
    },
    "judgments": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "key",
          "surface",
          "owner",
          "confidenceRule",
          "tests"
        ],
        "properties": {
          "key": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_.]+$"
          },
          "surface": {
            "enum": [
              "pr_comment",
              "dashboard",
              "pr_comment_and_dashboard",
              "operational_check"
            ]
          },
          "owner": {
            "type": "string",
            "pattern": "^packages/[a-z0-9-]+$"
          },
          "evidenceTypes": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
              "type": "string",
              "pattern": "^[A-Z][A-Z0-9_]+$"
            }
          },
          "confidenceRule": {
            "type": "string",
            "minLength": 30
          },
          "reasonCodes": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
              "$ref": "https://mergesignal.dev/schemas/reason-code-v1.json"
            }
          },
          "contractStates": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
              "type": "string",
              "pattern": "^[a-z_]+:[a-z_]+$"
            }
          },
          "tests": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
              "type": "string",
              "pattern": "^[a-z0-9][a-z0-9-]+$"
            }
          }
        },
        "allOf": [
          {
            "if": { "properties": { "surface": { "const": "operational_check" } } },
            "then": {
              "required": ["contractStates"],
              "properties": { "contractStates": { "type": "array" } }
            },
            "else": {
              "required": ["evidenceTypes", "reasonCodes"],
              "properties": {
                "evidenceTypes": { "type": "array" },
                "reasonCodes": { "type": "array" }
              }
            }
          }
        ]
      }
    }
  }
}
