{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mergesignal.dev/schemas/contextualization-request-envelope-v1.json",
  "title": "MergeSignal internal contextualization request binding",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "requestAlias", "assessmentId", "target", "requestNonce", "targetAlias", "targetAliasKeyVersion", "targetAliasScope", "safetyIdentifier", "safetyKeyVersion", "safetyScope", "safetyPrincipal", "evidenceAliases", "candidatePopulations", "instructionArtifactDigest", "requestSchemaArtifactDigest", "responseSchemaArtifactDigest", "modelParametersDigest", "providerRequestDigest", "providerInvocationDigest", "sentAt", "envelopeDigest"],
  "properties": {
    "schemaVersion": { "const": "1.0.0" },
    "requestAlias": { "type": "string", "format": "uuid" },
    "assessmentId": { "type": "string", "format": "uuid" },
    "target": {
      "type": "object",
      "additionalProperties": false,
      "required": ["installationId", "repositoryNodeId", "pullRequestNodeId", "pullRequestNumber", "headSha", "generation"],
      "properties": {
        "installationId": { "type": "integer", "minimum": 1 },
        "repositoryNodeId": { "type": "string", "minLength": 1 },
        "pullRequestNodeId": { "type": "string", "minLength": 1 },
        "pullRequestNumber": { "type": "integer", "minimum": 1 },
        "headSha": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
        "generation": { "type": "integer", "minimum": 1 }
      }
    },
    "requestNonce": { "type": "string", "format": "uuid" },
    "targetAlias": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "targetAliasKeyVersion": { "const": "target-alias-key-v1" },
    "targetAliasScope": { "const": "per_request_target" },
    "safetyIdentifier": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "safetyKeyVersion": { "const": "safety-key-v1" },
    "safetyScope": { "const": "installation_subject" },
    "safetyPrincipal": { "type": "string", "minLength": 1, "maxLength": 256 },
    "evidenceAliases": {
      "type": "array",
      "maxItems": 512,
      "uniqueItems": true,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["evidenceAlias", "evidenceId"],
        "properties": {
          "evidenceAlias": { "type": "string", "pattern": "^ev_[0-9a-f]{64}$" },
          "evidenceId": { "type": "string", "minLength": 1, "maxLength": 256 }
        }
      }
    },
    "candidatePopulations": {
      "type": "array",
      "maxItems": 24,
      "uniqueItems": true,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["claimId", "populationEvidenceIds", "populationCommitment"],
        "properties": {
          "claimId": { "type": "string", "pattern": "^[a-z][a-z0-9_-]+$" },
          "populationEvidenceIds": {
            "type": "array",
            "minItems": 1,
            "maxItems": 50000,
            "uniqueItems": true,
            "items": { "type": "string", "minLength": 1, "maxLength": 256 }
          },
          "populationCommitment": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
        }
      }
    },
    "instructionArtifactDigest": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "requestSchemaArtifactDigest": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "responseSchemaArtifactDigest": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "modelParametersDigest": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "providerRequestDigest": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "providerInvocationDigest": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "sentAt": { "type": "string", "format": "date-time" },
    "envelopeDigest": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
  }
}
