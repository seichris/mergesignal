{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mergesignal.dev/schemas/evidence-snapshot-manifest-v1.json",
  "title": "MergeSignal immutable evidence snapshot manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "snapshotId", "capturedAt", "versions", "versionDigests", "items"],
  "properties": {
    "schemaVersion": { "const": "1.0.0" },
    "snapshotId": { "type": "string", "format": "uuid" },
    "capturedAt": { "type": "string", "format": "date-time" },
    "versions": {
      "type": "object",
      "additionalProperties": false,
      "required": ["engine", "evidence", "features"],
      "properties": {
        "engine": { "type": "string", "pattern": "^engine-v[1-9][0-9]*$" },
        "evidence": { "type": "string", "pattern": "^evidence-v[1-9][0-9]*$" },
        "features": { "type": "string", "pattern": "^features-v[1-9][0-9]*$" }
      }
    },
    "versionDigests": {
      "type": "object",
      "additionalProperties": false,
      "required": ["engine", "evidence", "features"],
      "properties": {
        "engine": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
        "evidence": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
        "features": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
      }
    },
    "items": {
      "type": "array",
      "minItems": 1,
      "maxItems": 50000,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "evidenceId",
          "type",
          "visibility",
          "subjectGithubNodeId",
          "observedAt",
          "collectorVersion",
          "collectionRunId",
          "canonicalPayload"
        ],
        "properties": {
          "evidenceId": { "type": "string", "minLength": 1, "maxLength": 256 },
          "type": { "type": "string", "pattern": "^[A-Z][A-Z0-9_]+$" },
          "visibility": {
            "enum": [
              "PUBLIC_GLOBAL",
              "PUBLIC_DERIVED",
              "TARGET_REPOSITORY_PRIVATE",
              "SUBJECT_VISIBLE",
              "INTERNAL_OPERATIONAL"
            ]
          },
          "subjectGithubNodeId": {
            "type": ["string", "null"],
            "minLength": 1
          },
          "providerNodeId": { "type": "string", "minLength": 1, "maxLength": 256 },
          "eventAt": { "type": "string", "format": "date-time" },
          "observedAt": { "type": "string", "format": "date-time" },
          "collectorVersion": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9-]+-v[1-9][0-9]*$"
          },
          "collectionRunId": { "type": "string", "format": "uuid" },
          "canonicalPayload": {
            "type": "object",
            "minProperties": 1
          },
          "sourceUrl": {
            "type": "string",
            "format": "uri",
            "maxLength": 2048,
            "pattern": "^https://github\\.com/[^?#]+$"
          },
          "providerLocator": { "$ref": "#/$defs/providerLocator" },
          "repositoryNodeId": { "type": "string", "minLength": 1, "maxLength": 256 },
          "derivation": {
            "type": "object",
            "additionalProperties": false,
            "required": ["version", "inputEvidenceIds"],
            "properties": {
              "version": {
                "type": "string",
                "pattern": "^[a-z][a-z0-9-]+-v[1-9][0-9]*$"
              },
              "inputEvidenceIds": {
                "type": "array",
                "minItems": 1,
                "uniqueItems": true,
                "items": { "type": "string", "minLength": 1 }
              }
            }
          }
        },
        "allOf": [
          { "$ref": "https://mergesignal.dev/schemas/evidence-payload-v1.json" },
          {
            "if": {
              "properties": { "visibility": { "const": "PUBLIC_GLOBAL" } },
              "required": ["visibility"]
            },
            "then": {
              "required": ["sourceUrl", "providerLocator"],
              "properties": {
                "sourceUrl": { "type": "string" },
                "providerLocator": { "$ref": "#/$defs/providerLocator" }
              }
            },
            "else": {
              "properties": {
                "sourceUrl": false,
                "providerLocator": false
              }
            }
          },
          {
            "if": {
              "properties": {
                "visibility": {
                  "enum": ["TARGET_REPOSITORY_PRIVATE", "INTERNAL_OPERATIONAL"]
                }
              }
            },
            "then": {
              "required": ["repositoryNodeId"],
              "properties": {
                "repositoryNodeId": { "type": "string", "minLength": 1 }
              }
            }
          }
        ]
      }
    }
  },
  "$defs": {
    "providerLocator": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "nodeId", "login"],
          "properties": {
            "kind": { "const": "actor" },
            "nodeId": { "type": "string", "minLength": 1, "maxLength": 256 },
            "login": {
              "type": "string",
              "minLength": 1,
              "maxLength": 39,
              "pattern": "^[A-Za-z0-9](?:[A-Za-z0-9-]*[A-Za-z0-9])?$"
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "nodeId", "nameWithOwner"],
          "properties": {
            "kind": { "const": "repository" },
            "nodeId": { "type": "string", "minLength": 1, "maxLength": 256 },
            "nameWithOwner": {
              "type": "string",
              "minLength": 3,
              "maxLength": 201,
              "pattern": "^[A-Za-z0-9](?:[A-Za-z0-9-]*[A-Za-z0-9])?/[A-Za-z0-9._-]+$"
            }
          }
        }
      ]
    }
  }
}
