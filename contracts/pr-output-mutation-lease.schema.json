{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mergesignal.dev/schemas/pr-output-mutation-lease-v1.json",
  "title": "MergeSignal PR output mutation lease",
  "description": "A database-CAS lease that serializes publication and destructive cleanup for one PR. GitHub state is re-read only after this fencing token is held.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "leaseId",
    "installationId",
    "repositoryNodeId",
    "pullRequestNodeId",
    "cursorId",
    "cursorRevision",
    "cursorDigest",
    "purpose",
    "fencingToken",
    "publicationBlocked",
    "state",
    "databaseSnapshotToken",
    "acquiredAt",
    "expiresAt",
    "leaseDigest"
  ],
  "properties": {
    "schemaVersion": { "const": "1.0.0" },
    "leaseId": { "type": "string", "format": "uuid" },
    "installationId": { "type": "integer", "minimum": 1 },
    "repositoryNodeId": { "type": "string", "minLength": 1, "maxLength": 256 },
    "pullRequestNodeId": { "type": "string", "minLength": 1, "maxLength": 256 },
    "cursorId": { "type": "string", "format": "uuid" },
    "cursorRevision": { "type": "integer", "minimum": 1 },
    "cursorDigest": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "purpose": { "const": "terminal_comment_removal" },
    "fencingToken": { "type": "integer", "minimum": 1 },
    "publicationBlocked": { "const": true },
    "state": { "const": "held" },
    "databaseSnapshotToken": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "acquiredAt": { "type": "string", "format": "date-time" },
    "expiresAt": { "type": "string", "format": "date-time" },
    "leaseDigest": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
  }
}
