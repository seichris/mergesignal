{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mergesignal.dev/schemas/source-visibility-validation-v1.json",
  "title": "MergeSignal source-visibility validation record",
  "description": "An immutable observation of every assessment source and recursive provenance item at a publication fence.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "validationId",
    "assessmentId",
    "snapshotId",
    "installationId",
    "repositoryNodeId",
    "pullRequestNodeId",
    "pullRequestNumber",
    "headSha",
    "generation",
    "latestObservedHeadSha",
    "latestObservedGeneration",
    "outputCursorId",
    "outputCursorRevision",
    "outputCursorDigest",
    "outputCursorSnapshotToken",
    "outputCursorReadAt",
    "retentionTransitionId",
    "retentionRevision",
    "retentionState",
    "retentionHeadRevision",
    "retentionHeadDigest",
    "retentionSnapshotToken",
    "retentionHeadReadAt",
    "publicationAllowed",
    "phase",
    "expectedSourceSetDigest",
    "visibilityStateDigest",
    "publishable",
    "sources",
    "observedAt"
  ],
  "properties": {
    "schemaVersion": { "const": "1.0.0" },
    "validationId": { "type": "string", "format": "uuid" },
    "assessmentId": { "type": "string", "format": "uuid" },
    "snapshotId": { "type": "string", "format": "uuid" },
    "installationId": { "type": "integer", "minimum": 1 },
    "repositoryNodeId": { "type": "string", "minLength": 1 },
    "pullRequestNodeId": { "type": "string", "minLength": 1 },
    "pullRequestNumber": { "type": "integer", "minimum": 1 },
    "headSha": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
    "generation": { "type": "integer", "minimum": 1 },
    "latestObservedHeadSha": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
    "latestObservedGeneration": { "type": "integer", "minimum": 1 },
    "outputCursorId": { "type": "string", "format": "uuid" },
    "outputCursorRevision": { "type": "integer", "minimum": 1 },
    "outputCursorDigest": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "outputCursorSnapshotToken": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "outputCursorReadAt": { "type": "string", "format": "date-time" },
    "retentionTransitionId": { "type": "string", "format": "uuid" },
    "retentionRevision": { "type": "integer", "minimum": 1 },
    "retentionState": { "enum": ["retained", "source_tombstoned", "subject_deleted", "expired"] },
    "retentionHeadRevision": { "type": "integer", "minimum": 1 },
    "retentionHeadDigest": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "retentionSnapshotToken": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "retentionHeadReadAt": { "type": "string", "format": "date-time" },
    "publicationAllowed": { "type": "boolean" },
    "phase": { "enum": ["pre_write", "post_write", "post_check"] },
    "expectedSourceSetDigest": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "visibilityStateDigest": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "publishable": { "type": "boolean" },
    "sources": {
      "type": "array",
      "minItems": 1,
      "maxItems": 50000,
      "uniqueItems": true,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "evidenceId",
          "expectedVisibility",
          "currentVisibility",
          "expectedRepositoryNodeId",
          "currentRepositoryNodeId",
          "expectedRevision",
          "currentRevision",
          "visibilityObservedAt"
        ],
        "properties": {
          "evidenceId": { "type": "string", "minLength": 1, "maxLength": 256 },
          "expectedVisibility": {
            "enum": ["PUBLIC_GLOBAL", "PUBLIC_DERIVED", "TARGET_REPOSITORY_PRIVATE", "INTERNAL_OPERATIONAL"]
          },
          "currentVisibility": {
            "enum": ["PUBLIC_GLOBAL", "PUBLIC_DERIVED", "TARGET_REPOSITORY_PRIVATE", "INTERNAL_OPERATIONAL", "UNAVAILABLE"]
          },
          "expectedRepositoryNodeId": { "type": ["string", "null"], "minLength": 1 },
          "currentRepositoryNodeId": { "type": ["string", "null"], "minLength": 1 },
          "expectedRevision": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
          "currentRevision": { "type": ["string", "null"], "pattern": "^[0-9a-f]{64}$" },
          "visibilityObservedAt": { "type": "string", "format": "date-time" }
        }
      }
    },
    "observedAt": { "type": "string", "format": "date-time" }
  }
}
