{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mergesignal.dev/schemas/detailed-report-authorization-v1.json",
  "title": "MergeSignal maintainer detailed-report authorization",
  "description": "A short-lived, provider-backed authorization for one viewer, repository, assessment, nonce, and serializable policy-head snapshot.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "authorizationId",
    "authorityId",
    "sessionId",
    "requestNonce",
    "viewerGithubNodeId",
    "installationId",
    "repositoryNodeId",
    "repositoryPermission",
    "assessmentId",
    "assessmentDigest",
    "permissionObservationId",
    "permissionObservationDigest",
    "policyStreamId",
    "policyHeadRevision",
    "policyHeadRevisionId",
    "policyHeadDigest",
    "databaseSnapshotToken",
    "policyHeadReadAt",
    "authorizedAt",
    "expiresAt",
    "nonceConsumptionId",
    "nonceConsumptionDigest",
    "nonceConsumptionCommitToken",
    "authorizationDigest"
  ],
  "properties": {
    "schemaVersion": { "const": "1.0.0" },
    "authorizationId": { "type": "string", "format": "uuid" },
    "authorityId": { "type": "string", "format": "uuid" },
    "sessionId": { "type": "string", "format": "uuid" },
    "requestNonce": { "type": "string", "format": "uuid" },
    "viewerGithubNodeId": { "type": "string", "minLength": 1, "maxLength": 256 },
    "installationId": { "type": "integer", "minimum": 1 },
    "repositoryNodeId": { "type": "string", "minLength": 1, "maxLength": 256 },
    "repositoryPermission": { "enum": ["maintain", "admin"] },
    "assessmentId": { "type": "string", "format": "uuid" },
    "assessmentDigest": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "permissionObservationId": { "type": "string", "format": "uuid" },
    "permissionObservationDigest": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "policyStreamId": { "type": "string", "format": "uuid" },
    "policyHeadRevision": { "type": "integer", "minimum": 1 },
    "policyHeadRevisionId": { "type": "string", "format": "uuid" },
    "policyHeadDigest": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "databaseSnapshotToken": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "policyHeadReadAt": { "type": "string", "format": "date-time" },
    "authorizedAt": { "type": "string", "format": "date-time" },
    "expiresAt": { "type": "string", "format": "date-time" },
    "nonceConsumptionId": { "type": "string", "format": "uuid" },
    "nonceConsumptionDigest": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "nonceConsumptionCommitToken": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "authorizationDigest": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
  }
}
